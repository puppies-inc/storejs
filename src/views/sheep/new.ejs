<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New sheep</title>
  </head>
  <body>
    <h1>New sheep</h1>

    <% if (errors && errors.length > 0) { %>
      <ul>
        <% errors.forEach(function(error) { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/sheep" method="post">
      <p>
        <label for="name">Name</label>
        <input id="name" name="name" type="text" value="<%= sheep.name %>" />
      </p>
      <p>
        <button type="submit">Create Sheep</button>
      </p>
    </form>

    <p><a href="/sheep">Back to sheep</a></p>
  </body>
</html>
