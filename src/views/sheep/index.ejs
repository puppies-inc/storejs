<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sheep</title>
  </head>
  <body>
    <% if (notice) { %>
      <p><%= notice %></p>
    <% } %>

    <h1>Sheep</h1>

    <p><a href="/sheep/new">New sheep</a></p>

    <% if (sheep.length === 0) { %>
      <p>No sheep yet.</p>
    <% } %>

    <ul>
      <% sheep.forEach(function(sheepItem) { %>
        <li>
          Name: <%= sheepItem.name %>
          <a href="/sheep/<%= sheepItem.id %>">Show this sheep</a>
        </li>
      <% }) %>
    </ul>
  </body>
</html>
