<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Items</title>
  </head>
  <body>
    <% if (notice) { %>
      <p><%= notice %></p>
    <% } %>

    <h1>Items</h1>

    <p><a href="/items/new">New item</a></p>

    <% if (items.length === 0) { %>
      <p>No items yet.</p>
    <% } %>

    <ul>
      <% items.forEach(function(item) { %>
        <li>
          Name: <%= item.name %>
          <a href="/items/<%= item.id %>">Show this item</a>
        </li>
      <% }) %>
    </ul>
  </body>
</html>
